{
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "multiUser": false,
      "packages": "fzf kubectl, k9s, lazygit, nodejs, neovim, ripgrep, starship, stow, talosctl, tmux",
      "useAttributePath": true,
      "version": "latest"
    }
  },
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "mounts": [
    "type=bind,source=/home/${localEnv:USER}/.ssh,target=/home/vscode/.ssh,readonly"
  ],
  "onCreateCommand": "sudo chsh -s /usr/bin/zsh $USER && npm set prefix ~/.npm-global",
  "remoteEnv": {
    "LANG": "en_US.UTF-8",
    "PATH": "${containerEnv:PATH}:/home/vscode/.nix-profile/bin:/home/vscode/.npm-global/bin"
  }
}
